Task01-  Create Docker Containers for Multiple Applications

- name: Setup Docker Containers for Multiple Apps
  hosts: all
  become: yes
  tasks:
    - name: Pull Web App Image
      docker_image:
        name: my-web-app
        source: pull

    - name: Pull Database App Image
      docker_image:
        name: my-database-app
        source: pull
    
    - name: Run Web App Container 
      docker_container:
        name: web-app
        image: my-web-app
        state: started
        published_ports:
          - "8080:80"

    - name: Run Database App Container
      docker_container:
        name: my-database-app
        image: my-database-app
        state: started
        published_ports:
          - "3306:3306"


Task02 - Terraform - VPC with Private and Public Subnets

resource "aws_vpc" "main" {
  cidr_block = "10.0.1.0/16"
}

resource "aws_subnet" "public" {
  vpc_id                  = aws_vpc.main.id
  cidr_block              = "10.0.1.0/24"
  availability_zone       = "us-east-a"
  map_public_ip_on_launch = true
}

resource "aws_subnet" "private" {
  vpc_id             = aws_vpc.main.id
  cidr_block         = "10.0.2.0/24"
  availability_zone  = "us-east-1b"
}


Task03 -  Kubernetes — Deploying StatefulSet 

apiVersion: apps/v1
kind: Statefulset
metadata:
  name: pathnex-db
spec:
  serviceName: "pathnex-db"
  replicas: 3
  selector:
    matchLabels:
      app: pathnex-db
  template:
    metadata:
      labels:
        app: pathnex-db
    spec:
      containers:
        - name: db
          image: mysql:5.7
          volumeMounts:
            - mountPath: /var/lib/mysql
              name: mysql-storage
  volumeClaimTemplates:
    - metadata:
        name: mysql-storage
      spec:
        accessModes: ["ReadWriteOnce"]
        resources:
          requests:
            storage: 1Gi



Task04 - Jenkinsfile — Build and Deploy to Kubernetes

pipeline {
    agent any
    environment {
        IMAGE_NAME = 'pathnex-web-app'
    }
    stages {
        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("${env.IMAGE_NAME}")
                }
            }
        }
        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://docker.io', 'docker-credentials')  {
                        docker.image("${env.IMAGE_NAME}").push('latest')
                   }
                }
            }
        }
        stage('Deploy to Kubernetes') {
            steps {
                script {
                    sh 'kubectl apply -f deployment.yaml'
                }
            }
        }
    }
}


