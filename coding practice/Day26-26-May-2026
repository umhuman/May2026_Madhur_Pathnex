# Day 26 work — Security Best Practices


task01 - Ansible — Implementing SSH Key-based Authentication

- name: Implement SSH Key Authentication
  hosts: all
  become: yes
  tasks:
    - name: Generate SSH key pair
      command: ssh-keygen -t rsa -b 2048 -f /home/user/.ssh/id_rsa -N ""
    - name: Add SSH public key to authorized_key
      authorized_key:
        user: user
        state: present
        key: "{{ lookup('file', '/home/user/.ssh/id_rsa.pub') }}"




Task02 - Terraform — Enabling VPC Flow Logs for Security

resource "aws_vpc_flow_log" "pathnex_flow_log" {
  log_group_name          = "pathnex-flow-logs"
  vpc_id                  = aws_vpc.pathnex_vpc.id
  traffic_type            = "ALL"
  log_destination_type    = "cloud-watch-logs"
  iam_role_arn = aws_iam_role.flow_logs_role.arn
}

resource "aws_cloudwatch_log_group" "pathnex_flow_logs_group" {
  name = "pathnex-flow-logs"
}




Task03 -  Kubernetes — Network Policies for Security

apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: pathnex-web-policy
spec:
  podSelector:
    matchLabels:
      app: pathnex-web-app
  policyTypes:
    - Ingress
    - Egress
  ingress:
    - from:
        - podSelector:
            matchLabels:
              app: pathnex-api
  egress:
    - to:
        - podSelector:
            matchLabels:
              app: pathnex-database






Task04 - Jenkinsfile — Secure the Pipeline with Secrets


pipeline {
    agent any
    environment {
        AWS_ACCESS_KEY_ID      = credentials('aws-access-key')
        AWS_SECRET_ACCESS_KEY  = credentials('aws-secret-key') 
    }
    stages {
        stage('Build') {
            steps {
                echo 'Building Docker image...'
                docker.build('pathnex-web-app')
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying to AWS EC2...'
                sh 'aws ec2 run-instances --image-id ami-0abcd1234 --count 1 --instance-type t2.micro'
            }
        }
    }
}




