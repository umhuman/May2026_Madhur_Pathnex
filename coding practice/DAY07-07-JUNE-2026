# Day 07 — SPEED TYPING



# 1. Ansible: Install nginx
---
- name: Install and start Nginx 
  hosts: webservers
  become: yes

  tasks:
    - name: Install Nginx
      apt:
        name: nginx
        state: present
        update_cache: yes

    - name: Start and enable Nginx
      service:
        name: nginx
        state: started
        enabled: yes



