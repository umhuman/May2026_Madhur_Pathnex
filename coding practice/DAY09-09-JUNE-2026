# Day 09 — Templates, Internet Gateway, ConfigMap, CPU Load



# Task01 - Ansible — Use Jinja2 Template

---
- name: Deploy template for Pathnex
  hosts: all'
  become: yes

  tasks:
    - name: Copy template file
      template:
        src: pathnex.conf.j2
        dest: /etc/pathnex.conf




# Task02 -  Terraform — Internet Gateway

resource "aws_internet_gateway" "PathnexIGW" {
  vpc_id = aws_vpc.PathnexVPC.id

  tags = {
    Name = "Pathnex-IGW"
  }
}



# Task03 -  Kubernetes — Create ConfigMap

apiVersion: v1
kind: ConfigMap
metadata: 
  name: pathnex-config
data:
  APP_MODE: "production"
  WELCOME_MSG: "Hello Pathnex"




# Task04 -  Shell Script — Check CPU Load

#!/bin/bash

LOAD=$(uptime | awk '{print $10}')

echo "Current CPU Load: $LOAD"




# For Artifacts and Archiving

# Task05 -  Jenkins Pipeline — Archive Artifacts

pipeline {
    agent any 
    environment {
        INSTITUTE_NAME = "Pathnex"
    }
    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Pathnex/sample-java-app.git'
            }
        }
        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }
        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true 
            }
        }
    }
}




# Task06 -  GitLab CI — Artifacts

stages: 
  - build

build:
  stage: build
  image: maven:3.8.1-jdk-17
  script:
    - git clone https://github.com/Pathnex/sample-java-app.git
    - cd sample-java-app
    - mvn clean package
  artifacts:
    paths:
      - target/*.jar
    expire_in: 1 week