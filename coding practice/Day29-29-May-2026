Task02 -  Terraform — Provisioning Multi-Tier Application with VPC and Security


resource "aws_vpc" "pathnex_vpc" {
  cidr_block = "10.0.0.0/16"
}

resource "aws_instance" "pathnex_app" {
  ami              = "ami-0abcd1234abcd1234"
  instance_type    = "t2.medium"
  subnet_id        = aws_subnet.pathnex_subnet.id
  security_groups  = [aws_security_group.pathnex_sg.name]
}



Task03 -  Kubernetes — Deploy Full Application Stack

apiVersion: apps/v1
kind: Deployment
metadata:
  name: pathnex-db
spec:
  replicas:
  selector:
    matchLabels:
      app: pathnex-db
  template:
    metadata:
      labels:
        app: pathnex-db
    spec:
      containers:
        - name: nginx
          image: nginx
          ports:
            - containerPort: 80

---

apiVersion: v1
kind: Service
metadata:
  name: pathnex-db-service
spec:
  selector:
    app: pathnex-db
  ports:
    - port: 80
      targetPort: 80




