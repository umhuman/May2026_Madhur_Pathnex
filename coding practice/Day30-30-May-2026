Task07 - Kubernetes Network Security Policy to Restrict pod-to-pod communication

apiVersion: networking.k8s.io/v1
kind: NetworkPolicy

metadata:
  name: pathnex-policy

spec:
  podSelector:
    matchLabels:
      app: pathnex

  policyTypes:
    - Ingress

  ingress:
  - from:
    - podSelector:
        matchLabels:
          app: frontend


# Apply policy
kubectl apply -f network-policy.yaml





