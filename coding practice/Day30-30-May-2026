Task01 - Creating cloud infrastructure using Infrastructure as Code

provider "aws" {
  region = "ap-south-1"
}

resource "aws_vpc" "pathnex_vpc" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "pathnex-vpc"
  }
}

resource "aws_security_group" "pathnex_sg" {
  name   = "pathnex-sg"
  vpc_id = aws_vpc.pathnex_vpc.id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 8080
    to_port     = 8080
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}



Task02 - Package the application into a portable container

FROM node:20

WORKDIR /app

COPY . .

RUN npm install

EXPOSE 3000

CMD ["npm","start"]

# Build image

docker build -t pathnex:latest .


Task03 - Deploy application containers inside Kubernetes.

apiVersion: apps/v1
kind: Deployment

metadata:
  name: pathnex-app

spec:
  replicas: 3

  selector:
    matchLabels:
      app: pathnex

  template:
    metadata:
      labels:
        app: pathnex

    spec:
      containers:
      - name: pathnex

        image: yourdockerhub/pathnex:latest

        ports:
        - containerPort: 8080


# Deploy 
kubectl apply -f deployment.yaml


Task04 - Make the application accessible externally.

apiVersion: v1
kind: Service

metadata:
  name: pathnex-service

spec:
  type: LoadBalancer

  selector:
    app: pathnex

  ports:
  - port: 80
    targetPort: 8080




# Deploy 
kubectl apply -f service.yaml



